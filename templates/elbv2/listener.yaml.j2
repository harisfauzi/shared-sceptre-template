        Protocol: String
        Query: String
        StatusCode: String
      TargetGroupArn: String
      Type: String
  ListenerAttributes:
    -
      Key: String
      Value: String
  LoadBalancerArn: String
  MutualAuthentication:
    AdvertiseTrustStoreCaNames: String
