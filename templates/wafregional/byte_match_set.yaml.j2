---
Description: {{sceptre_user_data.description|default('WAFRegional Byte Match Set(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for byte_match_set in sceptre_user_data.byte_match_sets %}
{%- set byte_match_set_name = byte_match_set.name %}
  {{ byte_match_set_name }}:
    Type: AWS::WAFRegional::ByteMatchSet
    DeletionPolicy: {{ byte_match_set.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ byte_match_set.update_replace_policy | default('Delete') }}
    Properties:
      Name: {{ byte_match_set.byte_match_set_name }}
{%-if byte_match_set.byte_match_tuples is defined %}{# BEGIN if byte_match_set.byte_match_tuples is defined #}
      ByteMatchTuples:
{%- for byte_match_tuple in byte_match_set.byte_match_tuples %}{# BEGIN for byte_match_tuple in byte_match_set.byte_match_tuples #}
        - FieldToMatch:
            Type: {{ byte_match_tuple.field_to_match.type }}
{%- if byte_match_tuple.field_to_match.data is defined %}
            Data: {{ byte_match_tuple.field_to_match.data }}
{%- endif %}
          PositionalConstraint: {{ byte_match_tuple.positional_constraint }}
          TextTransformation: {{ byte_match_tuple.text_transformation }}
{%- if byte_match_tuple.target_string is defined %}
          TargetString:
            {{ byte_match_tuple.target_string }}
{%- endif %}
{%- if byte_match_tuple.target_string_base64 is defined %}
          TargetStringBase64: |-
            {{ byte_match_tuple.target_string_base64 | indent(width=12, first=false) }}
{%- endif %}
{%- endfor %}{# END for byte_match_tuple in byte_match_set.byte_match_tuples #}
{%- endif %}{# END if byte_match_set.byte_match_tuples is defined #}
{%- endfor %}

Outputs:
{%- for byte_match_set in sceptre_user_data.byte_match_sets %}
{%- set byte_match_set_name = byte_match_set.name %}
  {{ byte_match_set_name }}:
    Description: ID for {{ byte_match_set_name }}
    Value:
      Ref: {{ byte_match_set_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ byte_match_set_name }}"
{%- endfor %}{#
# Supported structure as of 2026-06-10
Type: AWS::WAFRegional::ByteMatchSet
Properties:
  ByteMatchTuples:
    -
      FieldToMatch:
        Data: String
        Type: String
      PositionalConstraint: String
      TargetString:
        String
      TargetStringBase64:
        String
      TextTransformation: String
  Name: String
#}