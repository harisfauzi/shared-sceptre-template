    Key:
      ActionId: String
      Description: String
      Parameters:
        Key: Value
      StartAfter:
        - String
      Targets:
        Key: Value
  Description: String
  ExperimentOptions:
    AccountTargeting: String
    EmptyTargetResolutionMode: String
  ExperimentReportConfiguration:
    DataSources:
      CloudWatchDashboards:
        -
          DashboardIdentifier: String
    Outputs:
      ExperimentReportS3Configuration:
        BucketName: String
        Prefix: String
    PostExperimentDuration: String
    PreExperimentDuration: String
  LogConfiguration:
    CloudWatchLogsConfiguration:
      LogGroupArn: String
    LogSchemaVersion: Integer
    S3Configuration:
      BucketName: String
      Prefix: String
  RoleArn: String
  StopConditions:
    -
      Source: String
      Value: String
  Tags:
    Key: Value
  Targets:
    Key:
      Filters:
        -
          Path: String
          Values:
            - String
      Parameters:
        Key: Value
      ResourceArns:
        - String
      ResourceTags:
        Key: Value
      ResourceType: String
      SelectionMode: String
#}