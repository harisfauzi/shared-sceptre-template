---
Description: {{sceptre_user_data.description|default('SecretsManager Rotation Schedule(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Transform: AWS::SecretsManager-2024-09-16

Resources:
{%- for rotation_schedule in sceptre_user_data.rotation_schedules %}
{%- set rotation_schedule_name = rotation_schedule.name %}
  {{ rotation_schedule_name }}:
    Type: AWS::SecretsManager::RotationSchedule
    DeletionPolicy: {{ rotation_schedule.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ rotation_schedule.update_replace_policy | default('Delete') }}
    Properties:
      SecretId: {{ rotation_schedule.secret_id | trim }}
{%- if rotation_schedule.external_secret_rotation_metadata is defined %}{# BEGIN if rotation_schedule.external_secret_rotation_metadata is defined #}
      ExternalSecretRotationMetadata:
{%- for metadata in rotation_schedule.external_secret_rotation_metadata %}
        -
          Key: {{ metadata.key }}
          Value: {{ metadata.value }}
{%- endfor %}
{%- endif %}{# END if rotation_schedule.external_secret_rotation_metadata is defined #}
{%- if rotation_schedule.external_secret_rotation_role_arn is defined %}
      ExternalSecretRotationRoleArn: {{ rotation_schedule.external_secret_rotation_role_arn | trim }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda is defined %}
      HostedRotationLambda:
        RotationType: {{ rotation_schedule.hosted_rotation_lambda.rotation_type }}
{%- if rotation_schedule.hosted_rotation_lambda.exclude_characters is defined %}
        ExcludeCharacters: {{ rotation_schedule.hosted_rotation_lambda.exclude_characters }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.kms_key_arn is defined %}
        KmsKeyArn: {{ rotation_schedule.hosted_rotation_lambda.kms_key_arn | trim }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.master_secret_arn is defined %}
        MasterSecretArn: {{ rotation_schedule.hosted_rotation_lambda.master_secret_arn | trim }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.master_secret_kms_key_arn is defined %}
        MasterSecretKmsKeyArn: {{ rotation_schedule.hosted_rotation_lambda.master_secret_kms_key_arn }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.rotation_lambda_name is defined %}
        RotationLambdaName: {{ rotation_schedule.hosted_rotation_lambda.rotation_lambda_name }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.runtime is defined %}
        Runtime: {{ rotation_schedule.hosted_rotation_lambda.runtime }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.superuser_secret_arn is defined %}
        SuperuserSecretArn: {{ rotation_schedule.hosted_rotation_lambda.superuser_secret_arn | trim }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.superuser_secret_kms_key_arn is defined %}
        SuperuserSecretKmsKeyArn: {{ rotation_schedule.hosted_rotation_lambda.superuser_secret_kms_key_arn | trim }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.vpc_security_group_ids is defined %}
        VpcSecurityGroupIds: {{ rotation_schedule.hosted_rotation_lambda.vpc_security_group_ids }}
{%- endif %}
{%- if rotation_schedule.hosted_rotation_lambda.vpc_subnet_ids is defined %}
        VpcSubnetIds: {{ rotation_schedule.hosted_rotation_lambda.vpc_subnet_ids }}
{%- endif %}
{%- endif %}
{%- if rotation_schedule.rotate_immediately_on_update is defined %}
      RotateImmediatelyOnUpdate: {{ rotation_schedule.rotate_immediately_on_update | lower }}
{%- endif %}
{%- if rotation_schedule.rotation_lambda_arn is defined %}
      RotationLambdaARN: {{ rotation_schedule.rotation_lambda_arn | trim }}
{%- endif %}
{%- if rotation_schedule.rotation_rules is defined %}{# BEGIN if rotation_schedule.rotation_rules is defined #}
      RotationRules:
{%- if rotation_schedule.rotation_rules.automatically_after_days is defined %}
        AutomaticallyAfterDays: {{ rotation_schedule.rotation_rules.automatically_after_days }}
{%- endif %}
{%- if rotation_schedule.rotation_rules.duration is defined %}
        Duration: {{ rotation_schedule.rotation_rules.duration }}
{%- endif %}
{%- if rotation_schedule.rotation_rules.schedule_expression is defined %}
        ScheduleExpression: {{ rotation_schedule.rotation_rules.schedule_expression }}
{%- endif %}
{%- endif %}{# END if rotation_schedule.rotation_rules is defined #}
{%- endfor %}

Outputs:
{%- for rotation_schedule in sceptre_user_data.rotation_schedules %}
{%- set rotation_schedule_name = rotation_schedule.name %}
  {{ rotation_schedule_name }}:
    Description: The Secret ARN for {{ rotation_schedule_name }}
    Value:
      Ref: {{ rotation_schedule_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ rotation_schedule_name }}"
{%- endfor %}{#
# Supported structure as of 2026-06-10:
Type: AWS::SecretsManager::RotationSchedule
Properties:
  ExternalSecretRotationMetadata:
    -
      Key: String
      Value: String
  ExternalSecretRotationRoleArn: String
  HostedRotationLambda:
    ExcludeCharacters: String
    KmsKeyArn: String
    MasterSecretArn: String
    MasterSecretKmsKeyArn: String
    RotationLambdaName: String
    RotationType: String
    Runtime: String
    SuperuserSecretArn: String
    SuperuserSecretKmsKeyArn: String
    VpcSecurityGroupIds: String
    VpcSubnetIds: String
  RotateImmediatelyOnUpdate: Boolean
  RotationLambdaARN: String
  RotationRules:
    AutomaticallyAfterDays: Integer
    Duration: String
    ScheduleExpression: String
  SecretId: String
#}