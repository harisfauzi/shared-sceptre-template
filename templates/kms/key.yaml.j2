---
Description: {{sceptre_user_data.description|default('KMS Key(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for key in sceptre_user_data.kms_keys %}
{%- set key_name = key.name %}
  {{ key_name }}:
    Type: AWS::KMS::Key
    DeletionPolicy: {{ key.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ key.update_replace_policy | default('Delete') }}
    Properties:
{%- if key.generic_key_policy is defined %}{# BEGIN if key.generic_key_policy is defined #}
      KeyPolicy:
        Version: '2012-10-17'
        Id: generic-key-policy
        Statement:
        - Sid: Enable IAM User Permissions
          Effect: Allow
          Principal:
            AWS:
              Fn::Sub: arn:aws:iam::${AWS::AccountId}:root
          Action: kms:*
          Resource: '*'
        - Sid: Allow administration of the key
          Effect: Allow
          Principal:
            AWS:
{%- for arn in key.generic_key_policy.administrator_arns %}
              - {{ arn }}
{%- endfor %}
          Action:
          - kms:Create*
          - kms:Describe*
          - kms:Enable*
          - kms:List*
          - kms:Put*
          - kms:Update*
          - kms:Revoke*
          - kms:Disable*
          - kms:Get*
          - kms:Delete*
          - kms:ScheduleKeyDeletion
          - kms:CancelKeyDeletion
          Resource: '*'
        - Sid: Allow use of the key
          Effect: Allow
          Principal:
            AWS:
{%- for arn in key.generic_key_policy.user_arns %}
              - {{ arn }}
{%- endfor %}
          Action:
          - kms:DescribeKey
          - kms:Encrypt
          - kms:Decrypt
          - kms:ReEncrypt*
          - kms:GenerateDataKey
          - kms:GenerateDataKeyWithoutPlaintext
          Resource: '*'
{%- else %}{# ELSE if key.generic_key_policy is defined #}
{%- if key.key_policy is defined %}
      KeyPolicy:
        {{ key.key_policy | indent(width=8, first=false) }}
{%- elif key.key_policy_json is defined %}
      KeyPolicy: |-
        {{ key.key_policy_json | indent(width=8, first=false) }}
{%- endif %}
{%- endif %}{# END if key.generic_key_policy is defined #}
{%- if key.bypass_policy_lockout_safety_check is defined %}
      BypassPolicyLockoutSafetyCheck: {{ key.bypass_policy_lockout_safety_check | lower }}
{%- endif %}
{%- if key.description is defined %}
      Description: {{ key.description }}
{%- endif %}
{%- if key.enabled is defined %}
      Enabled: {{ key.enabled | lower }}
{%- endif %}
{%- if key.enable_key_rotation is defined %}
      EnableKeyRotation: {{ key.enable_key_rotation | lower }}
{%- endif %}
{%- if key.key_spec is defined %}
      KeySpec: {{ key.key_spec }}
{%- endif %}
{%- if key.key_usage is defined %}
      KeyUsage: {{ key.key_usage }}
{%- endif %}
{%- if key.multi_region is defined %}
      MultiRegion: {{ key.multi_region | lower }}
{%- endif %}
{%- if key.origin is defined %}
      Origin: {{ key.origin }}
{%- endif %}
{%- if key.pending_window_in_days is defined %}
      PendingWindowInDays: {{ key.pending_window_in_days }}
{%- endif %}
{%- if key.rotation_period_in_days is defined %}
      RotationPeriodInDays: {{ key.rotation_period_in_days }}
{%- endif %}
      Tags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if key.tags is defined %}
{%- for key,value in key.tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- if key.alias_names is defined %}{# BEGIN if key.alias_names is defined #}
{%- set ns1 = namespace() %}
{%- set ns1.ii=0 %}
{%- for alias_name in key.alias_names %}{# BEGIN for alias_name in key.alias_names #}
{%- set ns1.ii=ns1.ii+1 %}
  {{ key_name ~ "Alias" ~ ns1.ii }}:
    Type: AWS::KMS::Alias
    DeletionPolicy: {{ key.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ key.update_replace_policy | default('Delete') }}
    Properties:
      AliasName: alias/{{ alias_name }}
      TargetKeyId:
        Ref: {{ key_name }}
{%- endfor %}{# END for alias_name in key.alias_names #}
{%- endif %}{# END if key.alias_names is defined #}
{%- endfor %}

Outputs:
{%- for key in sceptre_user_data.kms_keys %}
{%- set key_name = key.name %}
  {{ key_name }}:
    Description: The Key ID for {{ key_name }}
    Value:
      Ref: {{ key_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ key_name }}"
  {{ key_name }}Arn:
    Description: The ARN for {{ key_name }}
    Value:
      Fn::GetAtt:
      - {{ key_name }}
      - Arn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ key_name }}-Arn"
{%- if key.alias_names is defined %}
{%- set ns1 = namespace() %}
{%- set ns1.ii=0 %}
{%- for alias_name in key.alias_names %}
{%- set ns1.ii=ns1.ii+1 %}
  {{ key_name ~ "Alias" ~ ns1.ii }}:
    Description: The Alias for {{ key_name }}
    Value:
      Ref: {{ key_name ~ "Alias" ~ ns1.ii }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ key_name }}-Alias{{ ns1.ii }}"
{%- endfor %}
{%- endif %}
{%- endfor %}{#
# Supported structure as of 2026-06-10:
Type: AWS::KMS::Key
Properties:
  BypassPolicyLockoutSafetyCheck: Boolean
  Description: String
  Enabled: Boolean
  EnableKeyRotation: Boolean
  KeyPolicy: Json
  KeySpec: String
  KeyUsage: String
  MultiRegion: Boolean
  Origin: String
  PendingWindowInDays: Integer
  RotationPeriodInDays: Integer
  Tags:
    - Key: String
      Value: String

Type: AWS::KMS::Alias
Properties:
  AliasName: String
  TargetKeyId: String
#}