---
Description: {{sceptre_user_data.description|default('SES Custom Verification Email Template(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for custom_verification_email_template in sceptre_user_data.custom_verification_email_templates %}
{%- set custom_verification_email_template_name = custom_verification_email_template.name %}
  {{ custom_verification_email_template_name }}:
    Type: AWS::SES::CustomVerificationEmailTemplate
    DeletionPolicy: {{ custom_verification_email_template.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ custom_verification_email_template.update_replace_policy | default('Delete') }}
    Properties:
      FailureRedirectionURL: {{ custom_verification_email_template.failure_redirection_url }}
      FromEmailAddress: {{ custom_verification_email_template.from_email_address }}
      SuccessRedirectionURL: {{ custom_verification_email_template.success_redirection_url }}
      TemplateContent: |-
        {{ custom_verification_email_template.template_content | indent(width=8, first=false) }}
      TemplateName: {{ custom_verification_email_template.template_name }}
      TemplateSubject: {{ custom_verification_email_template.template_subject }}
      Tags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if custom_verification_email_template.tags is defined %}
{%- for key,value in custom_verification_email_template.tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- endfor %}

Outputs:
{%- for custom_verification_email_template in sceptre_user_data.custom_verification_email_templates %}
{%- set custom_verification_email_template_name = custom_verification_email_template.name %}
  {{ custom_verification_email_template_name }}:
    Description: Template name for {{ custom_verification_email_template_name }}
    Value:
      Ref: {{ custom_verification_email_template_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ custom_verification_email_template_name }}"
{%- endfor %}{#
# Supported structure as of 2026-06-14:
Type: AWS::SES::CustomVerificationEmailTemplate
Properties:
  FailureRedirectionURL: String
  FromEmailAddress: String
  SuccessRedirectionURL: String
  Tags:
    - Key: String
      Value: String
  TemplateContent: String
  TemplateName: String
  TemplateSubject: String
#}