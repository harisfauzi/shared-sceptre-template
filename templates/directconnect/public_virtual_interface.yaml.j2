---
Description: {{sceptre_user_data.description|default('DirectConnect Public Virtual Interface(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for public_virtual_interface in sceptre_user_data.public_virtual_interfaces %}
{%- set public_virtual_interface_name = public_virtual_interface.name %}
  {{ public_virtual_interface_name }}:
    Type: AWS::DirectConnect::PublicVirtualInterface
    DeletionPolicy: {{ public_virtual_interface.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ public_virtual_interface.update_replace_policy | default('Delete') }}
    Properties:
      BgpPeers:
{%- for bgp_peer in public_virtual_interface.bgp_peers %}{# BEGIN for bgp_peer in public_virtual_interface.bgp_peers #}
        -
          AddressFamily: {{ bgp_peer.address_family }}
          Asn: {{ bgp_peer.asn }}
{%- if bgp_peer.amazon_address is defined %}
          AmazonAddress: {{ bgp_peer.amazon_address }}
{%- endif %}
{%- if bgp_peer.auth_key is defined %}
          AuthKey: {{ bgp_peer.auth_key }}
{%- endif %}
{%- if bgp_peer.bgp_peer_id is defined %}
          BgpPeerId: {{ bgp_peer.bgp_peer_id }}
{%- endif %}
{%- if bgp_peer.customer_address is defined %}
          CustomerAddress: {{ bgp_peer.customer_address }}
{%- endif %}
{%- endfor %}{# END for bgp_peer in public_virtual_interface.bgp_peers #}
      ConnectionId: {{ public_virtual_interface.connection_id | trim }}
      VirtualInterfaceName: {{ public_virtual_interface.virtual_interface_name }}
      Vlan: {{ public_virtual_interface.vlan }}
{%- if public_virtual_interface.allocate_public_virtual_interface_role_arn is defined %}
      AllocatePublicVirtualInterfaceRoleArn: {{ public_virtual_interface.allocate_public_virtual_interface_role_arn | trim }}
{%- endif %}
{%- if public_virtual_interface.route_filter_prefixes is defined %}{# BEGIN if public_virtual_interface.route_filter_prefixes is defined #}
      RouteFilterPrefixes:
{%- for prefix in public_virtual_interface.route_filter_prefixes %}
        - {{ prefix }}
{%- endfor %}
{%- endif %}{# END if public_virtual_interface.route_filter_prefixes is defined #}
      Tags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if public_virtual_interface.tags is defined %}
{%- for key,value in public_virtual_interface.tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- endfor %}

Outputs:
{%- for public_virtual_interface in sceptre_user_data.public_virtual_interfaces %}
{%- set public_virtual_interface_name = public_virtual_interface.name %}
  {{ public_virtual_interface_name }}:
    Description: The ARN of the public virtual interface {{ public_virtual_interface_name }}
    Value:
      Ref: {{ public_virtual_interface_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ public_virtual_interface_name }}"
  {{ public_virtual_interface_name }}VirtualInterfaceArn:
    Description: The ARN of the public virtual interface {{ public_virtual_interface_name }}
    Value:
      Fn::GetAtt:
        - {{ public_virtual_interface_name }}
        - VirtualInterfaceArn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ public_virtual_interface_name }}-VirtualInterfaceArn"
  {{ public_virtual_interface_name }}VirtualInterfaceId:
    Description: The ID of the public virtual interface {{ public_virtual_interface_name }}
    Value:
      Fn::GetAtt:
        - {{ public_virtual_interface_name }}
        - VirtualInterfaceId
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ public_virtual_interface_name }}-VirtualInterfaceId"
{%- endfor %}{#
# Supported structure as of 2026-04-20
Type: AWS::DirectConnect::PublicVirtualInterface
Properties:
  AllocatePublicVirtualInterfaceRoleArn: String
  BgpPeers:
    -
      AddressFamily: String
      AmazonAddress: String
      Asn: String
      AuthKey: String
      BgpPeerId: String
      CustomerAddress: String
  ConnectionId: String
  RouteFilterPrefixes:
    - String
  Tags:
    -
      Key: String
      Value: String
  VirtualInterfaceName: String
  Vlan: Integer
#}