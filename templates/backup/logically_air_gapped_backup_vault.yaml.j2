---
Description: {{sceptre_user_data.description|default('Backup LogicallyAirGappedBackupVault(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for backup_vault in sceptre_user_data.backup_vaults %}
{%- set backup_vault_name = backup_vault.name %}
  {{ backup_vault_name }}:
    Type: AWS::Backup::LogicallyAirGappedBackupVault
    DeletionPolicy: {{ backup_vault.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ backup_vault.update_replace_policy | default('Delete') }}
    Properties:
      BackupVaultName: {{ backup_vault.backup_vault_name }}
      MaxRetentionDays: {{ backup_vault.max_retention_days }}
      MinRetentionDays: {{ backup_vault.min_retention_days }}
{%- if backup_vault.access_policy_json is defined %}
      AccessPolicy: {{ backup_vault.access_policy_json }}
{%- elif backup_vault.access_policy is defined %}
      AccessPolicy:
{{ backup_vault.access_policy | indent(width=8,first=true)}}
{%- endif %}
{%- if backup_vault.backup_vault_tags is defined %}{# BEGIN if backup_vault.backup_vault_tags is defined #}
      BackupVaultTags:
{%- for key, value in backup_vault.backup_vault_tags.items() %}
        {{ key }}: {{ value }}
{%- endfor %}
{%- endif %}{# END if backup_vault.backup_vault_tags is defined #}
{%- if backup_vault.encryption_key_arn is defined %}
      EncryptionKeyArn: {{ backup_vault.encryption_key_arn | trim }}
{%- endif %}
{%- if backup_vault.mpa_approval_team_arn is defined %}
      MpaApprovalTeamArn: {{ backup_vault.mpa_approval_team_arn | trim }}
{%- endif %}
{%- if backup_vault.notifications is defined %}
      Notifications:
        BackupVaultEvents:
{%- for backup_vault_event in backup_vault.notifications.backup_vault_events %}
          - {{ backup_vault_event }}
{%- endfor %}
        SNSTopicArn: {{ backup_vault.notifications.sns_topic_arn | trim }}
{%- endif %}
{%- endfor %}

Outputs:
{%- for backup_vault in sceptre_user_data.backup_vaults %}
{%- set backup_vault_name = backup_vault.name %}
  {{ backup_vault_name }}:
    Description: ARN of the backup vault {{ backup_vault_name }}
    Value:
      Ref: {{ backup_vault_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ backup_vault_name }}"
  {{ backup_vault_name }}BackupVaultArn:
    Description: The ARN for {{ backup_vault_name }}
    Value:
      Fn::GetAtt:
        - {{ backup_vault_name }}
        - BackupVaultArn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ backup_vault_name }}-BackupVaultArn"
  {{ backup_vault_name }}VaultState:
    Description: The vault state for {{ backup_vault_name }}
    Value:
      Fn::GetAtt:
        - {{ backup_vault_name }}
        - VaultState
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ backup_vault_name }}-VaultState"
  {{ backup_vault_name }}VaultType:
    Description: The vault type for {{ backup_vault_name }}
    Value:
      Fn::GetAtt:
        - {{ backup_vault_name }}
        - VaultType
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ backup_vault_name }}-VaultType"
{%- endfor %}{#
# Supported structure as of 2026-02-26
Type: AWS::Backup::LogicallyAirGappedBackupVault
Properties:
  AccessPolicy: Json
  BackupVaultName: String
  BackupVaultTags:
    Key: Value
  EncryptionKeyArn: String
  MaxRetentionDays: Integer
  MinRetentionDays: Integer
  MpaApprovalTeamArn: String
  Notifications:
    BackupVaultEvents:
      - String
    SNSTopicArn: String
#}