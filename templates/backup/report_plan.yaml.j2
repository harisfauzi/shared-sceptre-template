---
Description: {{sceptre_user_data.description|default('Backup ReportPlan(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for report_plan in sceptre_user_data.report_plans %}
{%- set report_plan_name = report_plan.name %}
  {{ report_plan_name }}:
    Type: AWS::Backup::ReportPlan
    DeletionPolicy: {{ report_plan.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ report_plan.update_replace_policy | default('Delete') }}
    Properties:
      ReportDeliveryChannel:
        S3BucketName: String
{%- if report_plan.report_delivery_channel.formats is defined %}{# BEGIN if report_plan.report_delivery_channel.formats is defined #}
        Formats:
{%- for format in report_plan.report_delivery_channel.formats %}
          - {{ format }}
{%- endfor %}
{%- endif %}{# END if report_plan.report_delivery_channel.formats is defined #}
{%- if report_plan.report_delivery_channel.s3_key_prefix is defined %}
        S3KeyPrefix: {{ report_plan.report_delivery_channel.s3_key_prefix }}
{%- endif %}
      ReportSetting:
        ReportTemplate: {{ report_plan.report_setting.report_template }}
{%- if report_plan.report_setting.accounts is defined %}
        Accounts:
{%- for account in report_plan.report_setting.accounts %}
          - {{ account }}
{%- endfor %}
{%- endif %}
{%- if report_plan.report_setting.framework_arns is defined %}
        FrameworkArns:
{%- for framework_arn in report_plan.report_setting.framework_arns %}
          - {{ framework_arn }}
{%- endfor %}
{%- endif %}
{%- if report_plan.report_setting.organization_units is defined %}
        OrganizationUnits:
{%- for organization_unit in report_plan.report_setting.organization_units %}
          - {{ organization_unit }}
{%- endfor %}
{%- endif %}
{%- if report_plan.report_setting.regions is defined %}
        Regions:
{%- for region in report_plan.report_setting.regions %}
          - {{ region }}
{%- endfor %}
{%- endif %}
{%- if report_plan.report_plan_description is defined %}
      ReportPlanDescription: {{ report_plan.report_plan_description }}
{%- endif %}
{%- if report_plan.report_plan_name is defined %}
      ReportPlanName: {{ report_plan.report_plan_name }}
{%- endif %}
      ReportPlanTags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if report_plan.report_plan_tags is defined %}
{%- for key,value in report_plan.report_plan_tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- endfor %}

Outputs:
{%- for report_plan in sceptre_user_data.report_plans %}
{%- set report_plan_name = report_plan.name %}
  {{ report_plan_name }}:
    Description: ReportPlan Name for {{ report_plan_name }}
    Value:
      Ref: {{ report_plan_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ report_plan_name }}"
  {{ report_plan_name }}ReportPlanArn:
    Description: The ARN for {{ report_plan_name }}
    Value:
      Fn::GetAtt:
        - {{ report_plan_name }}
        - ReportPlanArn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ report_plan_name }}-ReportPlanArn"
{%- endfor %}{#
# Supported structure as of 2026-02-26
Type: AWS::Backup::ReportPlan
Properties:
  ReportDeliveryChannel:
    Formats:
      - String
    S3BucketName: String
    S3KeyPrefix: String
  ReportPlanDescription: String
  ReportPlanName: String
  ReportPlanTags:
    - Key: String
      Value: String
  ReportSetting:
    Accounts:
      - String
    FrameworkArns:
      - String
    OrganizationUnits:
      - String
    Regions:
      - String
    ReportTemplate: String
#}