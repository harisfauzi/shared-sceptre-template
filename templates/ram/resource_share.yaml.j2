---
Description: {{sceptre_user_data.description|default('RAM Resource Share(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for resource_share in sceptre_user_data.resource_shares %}
{%- set resource_share_name = resource_share.name %}
  {{ resource_share_name }}:
    Type: AWS::RAM::ResourceShare
    DeletionPolicy: {{ resource_share.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ resource_share.update_replace_policy | default('Delete') }}
    Properties:
      Name: {{ resource_share_name }}
{%- if resource_share.allow_external_principals is defined %}
      AllowExternalPrincipals: {{ resource_share.allow_external_principals }}
{%- endif %}
{%- if resource_share.permission_arns is defined %}{# BEGIN if resource_share.permission_arns is defined #}
      PermissionArns:
{%- for permission_arn in resource_share.permission_arns %}
        - {{ permission_arn | trim }}
{%- endfor %}
{%- endif %}{# END if resource_share.permission_arns is defined #}
{%- if resource_share.principals is defined %}{# BEGIN if resource_share.principals is defined #}
      Principals:
{%- for principal in resource_share.principals %}
        - "{{ principal }}"
{%- endfor %}
{%- endif %}{# END if resource_share.principals is defined #}
{%- if resource_share.resource_arns is defined %}{# BEGIN if resource_share.resource_arns is defined #}
      ResourceArns:
{%- for resource_arn in resource_share.resource_arns %}
        - {{ resource_arn | trim }}
{%- endfor %}
{%- endif %}{# END if resource_share.resource_arns is defined #}
{%- if resource_share.sources is defined %}{# BEGIN if resource_share.sources is defined #}
      Sources:
{%- for source in resource_share.sources %}
        - {{ source }}
{%- endfor %}
{%- endif %}{# END if resource_share.sources is defined #}
      Tags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if resource_share.tags is defined %}
{%- for key,value in resource_share.tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- endfor %}

Outputs:
{%- for resource_share in sceptre_user_data.resource_shares %}
{%- set resource_share_name = resource_share.name %}
  {{ resource_share_name }}:
    Description: The ID for {{ resource_share_name }}
    Value:
      Ref: {{ resource_share_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ resource_share_name }}"
  {{ resource_share_name }}Arn:
    Description: ARN for {{ resource_share_name }}
    Value:
      Fn::GetAtt:
        - {{ resource_share_name }}
        - Arn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ resource_share_name }}-Arn"
  {{ resource_share_name }}Status:
    Description: Status for {{ resource_share_name }}
    Value:
      Fn::GetAtt:
        - {{ resource_share_name }}
        - Status
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ resource_share_name }}-Status"
{%- endfor %}{#
# Supported structure as of 2026-06-03
Type: AWS::RAM::ResourceShare
Properties:
  AllowExternalPrincipals: Boolean
  Name: String
  PermissionArns:
    - String
  Principals:
    - String
  ResourceArns:
    - String
  Sources:
    - String
  Tags:
    -
      Key: String
      Value: String
#}