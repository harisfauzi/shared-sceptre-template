    OracleSettings:
      AsmServer: String
      CertificateArn: String
      DatabaseName: String
      Port: Integer
      SecretsManagerOracleAsmAccessRoleArn: String
      SecretsManagerOracleAsmSecretId: String
      SecretsManagerSecurityDbEncryptionAccessRoleArn: String
      SecretsManagerSecurityDbEncryptionSecretId: String
      ServerName: String
      SslMode: String
    PostgreSqlSettings:
      CertificateArn: String
      DatabaseName: String
      Port: Integer
      ServerName: String
      SslMode: String
    RedshiftSettings:
      DatabaseName: String
      Port: Integer
      ServerName: String
    SybaseAseSettings:
      CertificateArn: String
      DatabaseName: String
      EncryptPassword: Boolean
      Port: Integer
      ServerName: String
      SslMode: String
  Tags:
    - Key: String
      Value: String
