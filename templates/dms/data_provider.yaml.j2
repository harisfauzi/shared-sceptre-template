      Port: Integer
      ServerName: String
      SslMode: String
    IbmDb2zOsSettings:
      CertificateArn: String
      DatabaseName: String
      Port: Integer
      ServerName: String
      SslMode: String
    MariaDbSettings:
      CertificateArn: String
      Port: Integer
      ServerName: String
      SslMode: String
    MicrosoftSqlServerSettings:
      CertificateArn: String
      DatabaseName: String
      Port: Integer
      ServerName: String
      SslMode: String
    MongoDbSettings:
      AuthMechanism: String
      AuthSource: String
      AuthType: String
      CertificateArn: String
      DatabaseName: String
      Port: Integer
      ServerName: String
      SslMode: String
    MySqlSettings:
      CertificateArn: String
      Port: Integer
      ServerName: String
