---
{%- import 'macros/helper.yaml.j2' as helper %}
Description: {{sceptre_user_data.description|default('DynamoDB Global Table(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for global_table in sceptre_user_data.global_tables %}
{%- set global_table_name = global_table.name %}
  {{ global_table_name }}:
    Type: AWS::DynamoDB::GlobalTable
    DeletionPolicy: {{ global_table.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ global_table.update_replace_policy | default('Delete') }}
    Properties:
      Replicas:
{%- for replica in global_table.replicas %}{# BEGIN for replica in global_table.replicas #}
        -
          Region: {{ replica.region }}
{%- if replica.contributor_insights_specification is defined %}
          ContributorInsightsSpecification:
            {{- helper.prep_contributor_insights_specification(replica.contributor_insights_specification) | indent(width=12, first=false) }}
{%- endif %}
{%- if replica.deletion_protection_enabled is defined %}
          DeletionProtectionEnabled: {{ replica.deletion_protection_enabled | lower }}
{%- endif %}
{%- if replica.global_secondary_indexes is defined %}{# BEGIN if replica.global_secondary_indexes is defined #}
          GlobalSecondaryIndexes:
{%- for index in replica.global_secondary_indexes %}{# BEGIN for index in replica.global_secondary_indexes #}
            -
              IndexName: {{ index.index_name }}
{%- if index.contributor_insights_specification is defined %}
              ContributorInsightsSpecification:
                {{- helper.prep_contributor_insights_specification(index.contributor_insights_specification) | indent(width=16, first=false) }}
{%- endif %}
{%- if index.read_on_demand_throughput_settings is defined %}{# BEGIN if index.read_on_demand_throughput_settings is defined #}
              ReadOnDemandThroughputSettings:
{%- if index.read_on_demand_throughput_settings.max_read_request_units is defined %}
                MaxReadRequestUnits: {{ index.read_on_demand_throughput_settings.max_read_request_units }}
{%- endif %}
{%- endif %}{# END if index.read_on_demand_throughput_settings is defined #}
{%- if index.read_provisioned_throughput_settings is defined %}
              ReadProvisionedThroughputSettings:
                {{- helper.prep_read_provisioned_throughput_settings(index.read_provisioned_throughput_settings) | indent(width=16, first=false) }}
{%- endif %}
{%- endfor %}{# END for index in replica.global_secondary_indexes #}
{%- endif %}{# END if replica.global_secondary_indexes is defined #}
{%- if replica.global_table_settings_replication_mode is defined %}
          GlobalTableSettingsReplicationMode: {{ replica.global_table_settings_replication_mode }}
{%- endif %}
{%- if replica.kinesis_stream_specification is defined %}{# BEGIN if replica.kinesis_stream_specification is defined #}
          KinesisStreamSpecification:
            StreamArn: {{ replica.kinesis_stream_specification.stream_arn }}
{%- if replica.kinesis_stream_specification.approximate_creation_date_time_precision is defined %}
            ApproximateCreationDateTimePrecision: {{ replica.kinesis_stream_specification.approximate_creation_date_time_precision }}
{%- endif %}
{%- endif %}{# END if replica.kinesis_stream_specification is defined #}
{%- if replica.point_in_time_recovery_specification is defined %}{# BEGIN if replica.point_in_time_recovery_specification is defined #}
          PointInTimeRecoverySpecification:
{%- if replica.point_in_time_recovery_specification.point_in_time_recovery_enabled is defined %}
            PointInTimeRecoveryEnabled: {{ replica.point_in_time_recovery_specification.point_in_time_recovery_enabled }}
{%- endif %}
{%- if replica.point_in_time_recovery_specification.recovery_period_in_days is defined %}
            RecoveryPeriodInDays: {{ replica.point_in_time_recovery_specification.recovery_period_in_days }}
{%- endif %}
{%- endif %}{# END if replica.point_in_time_recovery_specification is defined #}
{%- if replica.read_on_demand_throughput_settings is defined %}{# BEGIN if replica.read_on_demand_throughput_settings is defined #}
          ReadOnDemandThroughputSettings:
{%- if replica.read_on_demand_throughput_settings.max_read_request_units is defined %}
            MaxReadRequestUnits: {{ replica.read_on_demand_throughput_settings.max_read_request_units }}
{%- endif %}
{%- endif %}{# END if replica.read_on_demand_throughput_settings is defined #}
{%- if replica.read_provisioned_throughput_settings is defined %}
          ReadProvisionedThroughputSettings:
            {{- helper.prep_read_provisioned_throughput_settings(replica.read_provisioned_throughput_settings) | indent(width=12, first=false) }}
{%- endif %}
{%- if replica.replica_stream_specification is defined %}{# BEGIN if replica.replica_stream_specification is defined #}
          ReplicaStreamSpecification:
            ResourcePolicy:
{%- if replica.replica_stream_specification.resource_policy.policy_document is defined%}
              PolicyDocument:
                {{ replica.replica_stream_specification.resource_policy.policy_document | indent(width=16, first=false) }}
{%- elif replica.replica_stream_specification.resource_policy.policy_document_json is defined%}
              PolicyDocument: |-
                {{ replica.replica_stream_specification.resource_policy.policy_document_json | indent(width=16, first=false) }}
{%- endif %}
{%- endif %}{# END if replica.replica_stream_specification is defined #}
{%- if replica.resource_policy is defined %}{# BEGIN if replica.resource_policy is defined #}
          ResourcePolicy:
{%- if replica.resource_policy.policy_document is defined %}
            PolicyDocument:
              {{ replica.resource_policy.policy_document | indent(width=14, first=false) }}
{%- elif replica.resource_policy.policy_document_json is defined %}
            PolicyDocument: |-
              {{ replica.resource_policy.policy_document_json | indent(width=14, first=false) }}
{%- endif %}
{%- endif %}{# END if replica.resource_policy is defined #}
{%- if replica.sse_specification is defined %}
          SSESpecification:
            KMSMasterKeyId: {{ replica.sse_specification.kms_master_key_id | trim }}
{%- endif %}
{%- if replica.table_class is defined %}
          TableClass: {{ replica.table_class }}
{%- endif %}
{%- if replica.tags is defined %}{# BEGIN if replica.tags is defined #}
          Tags:
{%- for key,value in replica.tags.items() %}
            - Key: {{ key }}
              Value: {{ value }}
{%- endfor %}
{%- endif %}{# END if replica.tags is defined #}
{%- endfor %}{# END for replica in global_table.replicas #}
{%- if global_table.attribute_definitions is defined %}{# BEGIN if global_table.attribute_definitions is defined #}
      AttributeDefinitions:
{%- for attribute_definition in global_table.attribute_definitions %}
        -
          AttributeName: {{ attribute_definition.attribute_name }}
          AttributeType: {{ attribute_definition.attribute_type }}
{%- endfor %}
{%- endif %}{# END if global_table.attribute_definitions is defined #}
{%- if global_table.billing_mode is defined %}
      BillingMode: {{ global_table.billing_mode }}
{%- endif %}
{%- if global_table.global_secondary_indexes is defined %}{# BEGIN if global_table.global_secondary_indexes is defined #}
      GlobalSecondaryIndexes:
{%- for index in global_table.global_secondary_indexes %}{# BEGIN for index in global_table.global_secondary_indexes #}
        -
          IndexName: {{ index.index_name }}
          KeySchema:
{%- for schema in index.key_schema %}
            -
              {{- helper.prep_key_schema(schema) | indent(width=14, first=false) }}
{%- endfor %}
          Projection:
            {{- helper.prep_projection(index.projection) | indent(width=12, first=false) }}
{%- if index.read_on_demand_throughput_settings is defined %}{# BEGIN if index.read_on_demand_throughput_settings is defined #}
          ReadOnDemandThroughputSettings:
{%- if index.read_on_demand_throughput_settings.max_read_request_units is defined %}
            MaxReadRequestUnits: {{ index.read_on_demand_throughput_settings.max_read_request_units }}
{%- endif %}
{%- endif %}{# END if index.read_on_demand_throughput_settings is defined #}
{%- if index.read_provisioned_throughput_settings is defined %}
          ReadProvisionedThroughputSettings:
            {{- helper.prep_read_provisioned_throughput_settings(index.read_provisioned_throughput_settings) | indent(width=12, first=false) }}
{%- endif %}
{%- if index.warm_throughput is defined %}
          WarmThroughput:
            {{- helper.prep_warm_throughput(index.warm_throughput) | indent(width=12, first=false) }}
{%- endif %}
{%- if index.write_on_demand_throughput_settings is defined %}{# BEGIN if index.write_on_demand_throughput_settings is defined #}
          WriteOnDemandThroughputSettings:
{%- if index.write_on_demand_throughput_settings.max_write_request_units is defined %}
            MaxWriteRequestUnits: {{ index.write_on_demand_throughput_settings.max_write_request_units }}
{%- endif %}
{%- endif %}{# END if index.write_on_demand_throughput_settings is defined #}
{%- if index.write_provisioned_throughput_settings is defined %}{# BEGIN if index.write_provisioned_throughput_settings is defined #}
          WriteProvisionedThroughputSettings:
{%- if index.write_provisioned_throughput_settings.write_capacity_auto_scaling_settings is defined %}
            WriteCapacityAutoScalingSettings:
              {{- helper.prep_capacity_auto_scaling_settings(index.write_provisioned_throughput_settings.write_capacity_auto_scaling_settings) | indent(width=14, first=false) }}
{%- endif %}
{%- endif %}{# END if index.write_provisioned_throughput_settings is defined #}
{%- endfor %}{# END for index in global_table.global_secondary_indexes #}
{%- endif %}{# END if global_table.global_secondary_indexes is defined #}
{%- if global_table.global_table_source_arn is defined %}
      GlobalTableSourceArn: {{ global_table.global_table_source_arn | trim }}
{%- endif %}
{%- if global_table.global_table_witnesses is defined %}{# BEGIN if global_table.global_table_witnesses is defined #}
      GlobalTableWitnesses:
{%- for witness in global_table.global_table_witnesses %}
        - Region: {{ witness.region }}
{%- endfor %}
{%- endif %}{# END if global_table.global_table_witnesses is defined #}
{%- if global_table.key_schema is defined %}{# BEGIN if global_table.key_schema is defined #}
      KeySchema:
{%- for schema in global_table.key_schema %}
        -
          {{- helper.prep_key_schema(schema) | indent(width=10, first=false) }}
{%- endfor %}
{%- endif %}{# END if global_table.key_schema is defined #}
{%- if global_table.local_secondary_indexes is defined %}{# BEGIN if global_table.local_secondary_indexes is defined #}
      LocalSecondaryIndexes:
{%- for index in global_table.local_secondary_indexes %}{# BEGIN for index in global_table.local_secondary_indexes #}
        -
          IndexName: {{ index.index_name }}
          KeySchema:
{%- for schema in index.key_schema %}
            -
              {{- helper.prep_key_schema(schema) | indent(width=14, first=false) }}
{%- endfor %}
          Projection:
            {{- helper.prep_projection(index.projection) | indent(width=12, first=false) }}
{%- endfor %}{# END for index in global_table.local_secondary_indexes #}
{%- endif %}{# END if global_table.local_secondary_indexes is defined #}
{%- if global_table.multi_region_consistency is defined %}
      MultiRegionConsistency: {{ global_table.multi_region_consistency }}
{%- endif %}
{%- if global_table.read_on_demand_throughput_settings is defined %}{# BEGIN if global_table.read_on_demand_throughput_settings is defined #}
      ReadOnDemandThroughputSettings:
{%- if global_table.read_on_demand_throughput_settings.max_read_request_units is defined %}
        MaxReadRequestUnits: {{ global_table.read_on_demand_throughput_settings.max_read_request_units }}
{%- endif %}
{%- endif %}{# END if global_table.read_on_demand_throughput_settings is defined #}
{%- if global_table.read_provisioned_throughput_settings is defined %}{# BEGIN if global_table.read_provisioned_throughput_settings is defined #}
      ReadProvisionedThroughputSettings:
{%- if global_table.read_provisioned_throughput_settings.read_capacity_units is defined %}
        ReadCapacityUnits: {{ global_table.read_provisioned_throughput_settings.read_capacity_units }}
{%- endif %}
{%- endif %}{# END if global_table.read_provisioned_throughput_settings is defined #}
{%- if global_table.sse_specification is defined %}{# BEGIN if global_table.sse_specification is defined #}
      SSESpecification:
        SSEEnabled: {{ global_table.sse_specification.sse_enabled | lower }}
{%- if global_table.sse_specification.sse_type is defined %}
        SSEType: {{ global_table.sse_specification.sse_type }}
{%- endif %}
{%- endif %}{# END if global_table.sse_specification is defined #}
{%- if global_table.stream_specification is defined %}
      StreamSpecification:
        StreamViewType: {{ global_table.stream_specification.stream_view_type }}
{%- endif %}
{%- if global_table.table_name is defined %}
      TableName: {{ global_table.table_name }}
{%- endif %}
{%- if global_table.time_to_live_specification is defined %}{# BEGIN if global_table.time_to_live_specification is defined #}
      TimeToLiveSpecification:
        Enabled: {{ global_table.time_to_live_specification.enabled | lower }}
{%- if global_table.time_to_live_specification.attribute_name is defined %}
        AttributeName: {{ global_table.time_to_live_specification.attribute_name }}
{%- endif %}
{%- endif %}{# END if global_table.time_to_live_specification is defined #}
{%- if global_table.warm_throughput is defined %}
      WarmThroughput:
        {{- helper.prep_warm_throughput(global_table.warm_throughput) | indent(width=8, first=false) }}
{%- endif %}
{%- if global_table.write_on_demand_throughput_settings is defined %}{# BEGIN if global_table.write_on_demand_throughput_settings is defined #}
      WriteOnDemandThroughputSettings:
{%- if global_table.write_on_demand_throughput_settings.max_write_request_units is defined %}
        MaxWriteRequestUnits: {{ global_table.write_on_demand_throughput_settings.max_write_request_units }}
{%- endif %}
{%- endif %}{# END if global_table.write_on_demand_throughput_settings is defined #}
{%- if global_table.write_provisioned_throughput_settings is defined %}{# BEGIN if global_table.write_provisioned_throughput_settings is defined #}
      WriteProvisionedThroughputSettings:
{%- if global_table.write_provisioned_throughput_settings.write_capacity_auto_scaling_settings is defined %}
        WriteCapacityAutoScalingSettings:
          {{- helper.prep_capacity_auto_scaling_settings(global_table.write_provisioned_throughput_settings.write_capacity_auto_scaling_settings) | indent(width=10, first=false) }}
{%- endif %}
{%- endif %}{# END if global_table.write_provisioned_throughput_settings is defined #}
{%- endfor %}

Outputs:
{%- for global_table in sceptre_user_data.global_tables %}
{%- set global_table_name = global_table.name %}
  {{ global_table_name }}:
    Description: GlobalTable Name for {{ global_table_name }}
    Value:
      Ref: {{ global_table_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ global_table_name }}"
  {{ global_table_name }}Arn:
    Description: The ARN for {{ global_table_name }}
    Value:
      Fn::GetAtt:
        - {{ global_table_name }}
        - Arn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ global_table_name }}-Arn"
{%- if global_table.stream_specification is defined %}
  {{ global_table_name }}StreamArn:
    Description: The ARN of the DynamoDB stream for {{ global_table_name }}
    Value:
      Fn::GetAtt:
        - {{ global_table_name }}
        - StreamArn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ global_table_name }}-StreamArn"
{%- endif %}
  {{ global_table_name }}TableId:
    Description: Unique identifier for the table {{ global_table_name }}
    Value:
      Fn::GetAtt:
        - {{ global_table_name }}
        - TableId
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ global_table_name }}-TableId"
{%- endfor %}{#
