---
{%- import 'macros/macro_load_balancer.yaml.j2' as macro_load_balancer %}
{%- import 'macros/macro_network_configuration.yaml.j2' as macro_network_configuration %}
{%- import 'macros/macro_service_registry.yaml.j2' as macro_service_registry %}
Description: {{sceptre_user_data.description|default('ECS Task Set(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for task_set in sceptre_user_data.task_sets %}
{%- set task_set_name = task_set.name %}
  {{ task_set_name }}:
    Type: AWS::ECS::TaskSet
    DeletionPolicy: {{ task_set.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ task_set.update_replace_policy | default('Delete') }}
    Properties:
      Cluster: {{ task_set.cluster }}
      Service: {{ task_set.service }}
      TaskDefinition: {{ task_set.task_definition }}
{%- if task_set.capacity_provider_strategy is defined %}{# BEGIN if task_set.capacity_provider_strategy is defined #}
      CapacityProviderStrategy:
{%- for strategy in task_set.capacity_provider_strategy %}{# BEGIN for strategy in task_set.capacity_provider_strategy #}
        -
{%- if strategy.base is defined %}
          Base: {{ strategy.base }}
{%- endif %}
{%- if strategy.capacity_provider is defined %}
          CapacityProvider: {{ strategy.capacity_provider }}
{%- endif %}
{%- if strategy.weight is defined %}
          Weight: {{ strategy.weight }}
{%- endif %}
{%- endfor %}{# END for strategy in task_set.capacity_provider_strategy #}
{%- endif %}{# END if task_set.capacity_provider_strategy is defined #}
{%- if task_set.external_id is defined %}
      ExternalId: {{ task_set.external_id | trim }}
{%- endif %}
{%- if task_set.launch_type is defined %}
      LaunchType: {{task_set.launch_type }}
{%- endif %}
{%- if task_set.load_balancers is defined %}{# BEGIN if task_set.load_balancers is defined #}
      LoadBalancers:
        {{- macro_load_balancer.prep(task_set.load_balancers) | indent(width=8, first=false) }}
{%- endif %}{# END if task_set.load_balancers is defined #}
{%- if task_set.network_configuration is defined %}{# BEGIN if task_set.network_configuration is defined #}
      {{- macro_network_configuration.prep(task_set.network_configuration) | indent(width=6, first=false) }}
{%- endif %}{# END if task_set.network_configuration is defined #}
{%- if task_set.platform_version is defined %}
      PlatformVersion: {{ task_set.platform_version }}
{%- endif %}
{%- if task_set.scale is defined %}{# BEGIN if task_set.scale is defined #}
      Scale:
{%- if task_set.scale.unit is defined %}
        Unit: {{ task_set.scale.unit }}
{%- endif %}
{%- if task_set.scale.value is defined %}
        Value: {{ task_set.scale.value }}
{%- endif %}
{%- endif %}{# END if task_set.scale is defined #}
{%- if task_set.service_registries is defined %}
      ServiceRegistries:
        {{- macro_service_registry.prep(task_set.service_registries) | indent(width=8, first=false) }}
{%- endif %}
      Tags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if task_set.tags is defined %}
{%- for key,value in task_set.tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- endfor %}

Outputs:
{%- for task_set in sceptre_user_data.task_sets %}
{%- set task_set_name = task_set.name %}
  {{ task_set_name }}:
    Description: Resource name for {{ task_set_name }}
    Value:
      Ref: {{ task_set_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ task_set_name }}"
  {{ task_set_name }}Id:
    Description: The ID of the task set for {{ task_set_name }}
    Value:
      Fn::GetAtt:
        - {{ task_set_name }}
        - Id
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ task_set_name }}-Id"
{%- endfor %}{#
# Supported structure as of 2026-03-05:
Type: AWS::ECS::TaskSet
Properties:
  CapacityProviderStrategy:
    -
      Base: Integer
      CapacityProvider: String
      Weight: Integer
  Cluster: String
  ExternalId: String
  LaunchType: String
  LoadBalancers:
    -
      ContainerName: String
      ContainerPort: Integer
      TargetGroupArn: String
  NetworkConfiguration:
    AwsVpcConfiguration:
      AssignPublicIp: String
      SecurityGroups:
        - String
      Subnets:
        - String
  PlatformVersion: String
  Scale:
    Unit: String
    Value: Number
  Service: String
  ServiceRegistries:
    -
      ContainerName: String
      ContainerPort: Integer
      Port: Integer
      RegistryArn: String
  Tags:
    -
      Key: String
      Value: String
  TaskDefinition: String
#}