---
Description: {{sceptre_user_data.description|default('EC2 Local Gateway Route Virtual Interface Group Association(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for local_gateway_route_table_virtual_interface_group_association in sceptre_user_data.local_gateway_route_table_virtual_interface_group_associations %}
{%- set local_gateway_route_table_virtual_interface_group_association_name = local_gateway_route_table_virtual_interface_group_association.name %}
  {{ local_gateway_route_table_virtual_interface_group_association_name }}:
    Type: AWS::EC2::LocalGatewayRouteTableVirtualInterfaceGroupAssociation
    DeletionPolicy: {{ local_gateway_route_table_virtual_interface_group_association.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ local_gateway_route_table_virtual_interface_group_association.update_replace_policy | default('Delete') }}
    Properties:
      LocalGatewayRouteTableId: {{ local_gateway_route_table_virtual_interface_group_association.local_gateway_route_table_id | trim }}
      LocalGatewayVirtualInterfaceGroupId: {{ local_gateway_route_table_virtual_interface_group_association.local_gateway_virtual_interface_group_id | trim }}
      Tags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if local_gateway_route_table_virtual_interface_group_association.tags is defined %}
{%- for key,value in local_gateway_route_table_virtual_interface_group_association.tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- endfor %}

Outputs:
{%- for local_gateway_route_table_virtual_interface_group_association in sceptre_user_data.local_gateway_route_table_virtual_interface_group_associations %}
{%- set local_gateway_route_table_virtual_interface_group_association_name = local_gateway_route_table_virtual_interface_group_association.name %}
  {{ local_gateway_route_table_virtual_interface_group_association_name }}:
    Description: The ID of the local gateway route table virtual interface group association for {{ local_gateway_route_table_virtual_interface_group_association_name }}
    Value:
      Ref: {{ local_gateway_route_table_virtual_interface_group_association_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ local_gateway_route_table_virtual_interface_group_association_name }}"
  {{ local_gateway_route_table_virtual_interface_group_association_name }}LocalGatewayRouteTableArn:
    Description: The ARN of the local gateway route table for {{ local_gateway_route_table_virtual_interface_group_association_name }}
    Value:
      Fn::GetAtt:
        - {{ local_gateway_route_table_virtual_interface_group_association_name }}
        - LocalGatewayRouteTableArn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ local_gateway_route_table_virtual_interface_group_association_name }}-LocalGatewayRouteTableArn"
  {{ local_gateway_route_table_virtual_interface_group_association_name }}LocalGatewayId:
    Description: The ID of the local gateway for {{ local_gateway_route_table_virtual_interface_group_association_name }}
    Value:
      Fn::GetAtt:
        - {{ local_gateway_route_table_virtual_interface_group_association_name }}
        - LocalGatewayId
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ local_gateway_route_table_virtual_interface_group_association_name }}-LocalGatewayId"
  {{ local_gateway_route_table_virtual_interface_group_association_name }}LocalGatewayRouteTableVirtualInterfaceGroupAssociationId:
    Description: The ID of the association for {{ local_gateway_route_table_virtual_interface_group_association_name }}
    Value:
      Fn::GetAtt:
        - {{ local_gateway_route_table_virtual_interface_group_association_name }}
        - LocalGatewayRouteTableVirtualInterfaceGroupAssociationId
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ local_gateway_route_table_virtual_interface_group_association_name }}-LocalGatewayRouteTableVirtualInterfaceGroupAssociationId"
  {{ local_gateway_route_table_virtual_interface_group_association_name }}OwnerId:
    Description: The AWS account ID that owns the local gateway route table virtual interface group association for {{ local_gateway_route_table_virtual_interface_group_association_name }}
    Value:
      Fn::GetAtt:
        - {{ local_gateway_route_table_virtual_interface_group_association_name }}
        - OwnerId
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ local_gateway_route_table_virtual_interface_group_association_name }}-OwnerId"
  {{ local_gateway_route_table_virtual_interface_group_association_name }}State:
    Description: The state of the local gateway route table virtual interface group association for {{ local_gateway_route_table_virtual_interface_group_association_name }}
    Value:
      Fn::GetAtt:
        - {{ local_gateway_route_table_virtual_interface_group_association_name }}
        - State
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ local_gateway_route_table_virtual_interface_group_association_name }}-State"
{%- endfor %}{#
