---
Description: {{sceptre_user_data.description|default('Route Server Propagation(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for route_server_propagation in sceptre_user_data.route_server_propagations %}
{%- set route_server_propagation_name = route_server_propagation.name %}
  {{ route_server_propagation_name }}:
    Type: AWS::EC2::RouteServerPropagation
    DeletionPolicy: {{ route_server_propagation.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ route_server_propagation.update_replace_policy | default('Delete') }}
    Properties:
      RouteServerId: {{ route_server_propagation.route_server_id | trim }}
      RouteTableId: {{ route_server_propagation.route_table_id | trim }}
{%- endfor %}

Outputs:
{%- for route_server_propagation in sceptre_user_data.route_server_propagations %}
{%- set route_server_propagation_name = route_server_propagation.name %}
  {{ route_server_propagation_name }}:
    Description: Route server ID and route table ID separated by the pipe symbol (|) for {{ route_server_propagation_name }}
    Value:
      Ref: {{ route_server_propagation_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ route_server_propagation_name }}"
{%- endfor %}{#
# Supported structure as of 2026-04-19:
Type: AWS::EC2::RouteServerPropagation
Properties:
  RouteServerId: String
  RouteTableId: String
#}