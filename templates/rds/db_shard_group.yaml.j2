---
Description: {{sceptre_user_data.description|default('RDS DB Shard Group(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for db_shard_group in sceptre_user_data.db_shard_groups %}
{%- set db_shard_group_name = db_shard_group.name %}
  {{ db_shard_group_name }}:
    Type: AWS::RDS::DBShardGroup
    DeletionPolicy: {{ db_shard_group.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ db_shard_group.update_replace_policy | default('Delete') }}
    Properties:
      DBClusterIdentifier: {{ db_shard_group.db_cluster_identifier }}
      MaxACU: {{ db_shard_group.max_acu }}
{%- if db_shard_group.compute_redundancy is defined %}
      ComputeRedundancy: {{ db_shard_group.compute_redundancy }}
{%- endif %}
{%- if db_shard_group.db_shard_group_identifier is defined %}
      DBShardGroupIdentifier: {{ db_shard_group.db_shard_group_identifier }}
{%- endif %}
{%- if db_shard_group.min_acu is defined %}
      MinACU: {{ db_shard_group.min_acu }}
{%- endif %}
{%- if db_shard_group.publicly_accessible is defined %}
      PubliclyAccessible: {{ db_shard_group.publicly_accessible | lower }}
{%- endif %}
      Tags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if db_shard_group.tags is defined %}
{%- for key,value in db_shard_group.tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- endfor %}

Outputs:
{%- for db_shard_group in sceptre_user_data.db_shard_groups %}
{%- set db_shard_group_name = db_shard_group.name %}
  {{ db_shard_group_name }}:
    Description: The name of the DB cluster identifier for {{ db_shard_group_name }}
    Value:
      Ref: {{ db_shard_group_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ db_shard_group_name }}"
  {{ db_shard_group_name }}DBShardGroupResourceId:
    Description: >
      The AWS Region-unique, immutable identifier for the DB shard group for {{ db_shard_group_name }}
    Value:
      Fn::GetAtt:
        - {{ db_shard_group_name }}
        - DBShardGroupResourceId
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ db_shard_group_name }}-DBShardGroupResourceId"
{%- endfor %}{#
# Supported structure as of 2026-06-03:
Type: AWS::RDS::DBShardGroup
Properties:
  ComputeRedundancy: Integer
  DBClusterIdentifier: String
  DBShardGroupIdentifier: String
  MaxACU: Number
  MinACU: Number
  PubliclyAccessible: Boolean
  Tags:
    - Key: String
      Value: String
#}