---
Description: {{sceptre_user_data.description|default('Logs LogGroup(s) for '+sceptre_user_data.project_code)}}
AWSTemplateFormatVersion: "2010-09-09"

Resources:
{%- for log_group in sceptre_user_data.log_groups %}
{%- set log_group_name = log_group.name %}
  {{ log_group_name }}:
    Type: AWS::Logs::LogGroup
    DeletionPolicy: {{ log_group.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ log_group.update_replace_policy | default('Delete') }}
    Properties:
{%- if log_group.bearer_token_authentication_enabled is defined %}
      BearerTokenAuthenticationEnabled: {{ log_group.bearer_token_authentication_enabled | lower }}
{%- endif %}
{%- if log_group.deletion_protection_enabled is defined %}
      DeletionProtectionEnabled: {{ log_group.deletion_protection_enabled | lower }}
{%- endif %}
{%- if log_group.field_index_policies is defined %}{# BEGIN if log_group.field_index_policies is defined #}
      FieldIndexPolicies:
{%- for key,value in log_group.field_index_policies.items() %}
        - {{ key }}: {{ value }}
{%- endfor %}
{%- endif %}{# END if log_group.field_index_policies is defined #}
{%- if log_group.log_group_class is defined %}
      LogGroupClass: {{ log_group.log_group_class }}
{%- endif %}
{%- if log_group.resource_policy_document is defined %}
      ResourcePolicyDocument:
        {{log_group.resource_policy_document|indent(width=8, first=false)}}
{%- elif log_group.resource_policy_document_json is defined %}
      ResourcePolicyDocument: |
        {{log_group.resource_policy_document_json | indent(width=8, first=false)}}
{%- endif %}
{%- if log_group.data_protection_policy is defined %}
      DataProtectionPolicy:
        {{log_group.data_protection_policy|indent(width=8, first=false)}}
{%- elif log_group.data_protection_policy_json is defined %}
      DataProtectionPolicy: |
        {{log_group.data_protection_policy_json | indent(width=8, first=false)}}
{%- endif %}
{%- if log_group.kms_key_id is defined %}
      KmsKeyId: {{ log_group.kms_key_id | trim }}
{%- endif %}
{%- if log_group.log_group_name is defined %}
      LogGroupName: {{ log_group.log_group_name }}
{%- endif %}
{%- if log_group.retention_in_days is defined %}
      RetentionInDays: {{ log_group.retention_in_days }}
{%- endif %}
      Tags:
        - Key: SourceRepoURL
          Value: {{ sceptre_user_data.source_repo_url | default('unknown') }}
{%- if log_group.tags is defined %}
{%- for key,value in log_group.tags.items() %}
        - Key: {{ key }}
          Value: {{ value }}
{%- endfor %}
{%- endif %}
{%- if log_group.streams is defined %}{# BEGIN if log_group.streams is defined #}
{%- set ns1 = namespace() %}
{%- set ns1.ii = 0 %}
{%- for stream in log_group.streams %}
{%- set ns1.ii = ns1.ii + 1 %}
{%- set stream_name = log_group_name + ("%03d" % ns1.ii) %}
  {{stream_name}}:
    Type: AWS::Logs::LogStream
    DeletionPolicy: {{ log_group.deletion_policy | default('Delete') }}
    UpdateReplacePolicy: {{ log_group.update_replace_policy | default('Delete') }}
    Properties:
      LogGroupName:
        Ref: {{ log_group_name }}
      LogStreamName: {{ stream }}
{%- endfor %}
{%- endif %}{# END if log_group.streams is defined #}
{%- endfor %}

Outputs:
{%- for log_group in sceptre_user_data.log_groups %}
{%- set log_group_name = log_group.name %}
  {{ log_group_name }}:
    Description: Resource Name for {{ log_group_name }}
    Value:
      Ref: {{ log_group_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ log_group_name }}"
  {{ log_group_name }}Arn:
    Description: The ARN for {{ log_group_name }}
    Value:
      Fn::GetAtt:
        - {{ log_group_name }}
        - Arn
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ log_group_name }}-Arn"
{%- if log_group.streams is defined %}{# BEGIN if log_group.streams is defined #}
{%- set ns1 = namespace() %}
{%- set ns1.ii = 0 %}
{%- for stream in log_group.streams %}
{%- set ns1.ii = ns1.ii + 1 %}
{%- set stream_name = log_group_name + ("%03d" % ns1.ii) %}
  {{ stream_name }}:
    Description: Stream Name for {{ stream_name }}
    Value:
      Ref: {{ stream_name }}
    Export:
      Name:
        Fn::Sub: "${AWS::StackName}-{{ log_group_name }}-stream{{ "%03d" % ns1.ii }}"
{%- endfor %}
{%- endif %}{# END if log_group.streams is defined #}
{%- endfor %}{#
# Supported structure as of 2026-03-28:
Type: AWS::Logs::LogGroup
Properties:
  BearerTokenAuthenticationEnabled: Boolean
  DataProtectionPolicy: Json
  DeletionProtectionEnabled: Boolean
  FieldIndexPolicies:
    -
      Key: Value
  KmsKeyId: String
  LogGroupClass: String
  LogGroupName: String
  ResourcePolicyDocument: Json
  RetentionInDays: Integer
  Tags:
    -
      Key: String
      Value: String
Type: AWS::Logs::LogStream
Properties:
  LogGroupName: String
  LogStreamName: String
#}